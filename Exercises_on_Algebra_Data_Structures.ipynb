      "source": [
        "import numpy as np"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "s = 1"
      ],
      "metadata": {
        "id": "OXlFJ7TT5BZi"
      },
      "execution_count": 2,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# vektor kolom\n",
        "v = np.array([[2*s],\n",
        "              [2],\n",
        "              [-3],\n",
        "              [-2*s]])"
      ],
      "metadata": {
        "id": "J56oeUmD5FgC"
      },
      "execution_count": 3,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# transpose\n",
        "v_T = v.T\n",
        "\n",
        "print(\"Vektor awal:\\n\", v)\n",
        "print(\"Transpose:\\n\", v_T)"
      ],
      "metadata": {
        "colab": {
